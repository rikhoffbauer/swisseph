{
  "author": "mivion",
  "name": "swisseph",
  "description": "Swiss Ephemeris binding for node.js",
  "version": "0.5.18",
  "homepage": "http://github.com/mivion/swisseph",
  "repository": {
    "url": "http://github.com/mivion/swisseph.git"
  },
  "main": "./lib/swisseph.js",
  "types": "./dist/types/browser/index.d.ts",
  "keywords": [
    "swiss",
    "ephemeris",
    "astrology",
    "astronomy"
  ],
  "dependencies": {
    "merge": "^2.1.1",
    "nan": "^2.20.0",
    "node-gyp": "^11.0.0"
  },
  "engines": {
    "node": ">=8"
  },
  "scripts": {
    "install": "node-gyp rebuild",
    "test": "node test/test.js",
    "start": "node app.js",
    "build:wasm": "bash scripts/build-wasm.sh",
    "build:ts": "tsc",
    "build": "npm run build:wasm && npm run build:ts",
    "prepublishOnly": "npm run build"
  },
  "module": "./dist/esm/browser/index.js",
  "exports": {
    ".": {
      "import": "./dist/esm/browser/index.js",
      "require": "./lib/swisseph.js"
    }
  },
  "devDependencies": {
    "typescript": "^5.4.5"
  }
}
